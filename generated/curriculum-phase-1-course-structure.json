  "title": "Bolo English Complete Learning System",
  "outcome": "A full journey from zero English to advanced, confident, professional English communication.",
  "systems": {
    "grammar_system": {
      "design_principles": [
        "Grammar appears in practical speaking situations before it is named explicitly.",
        "Each grammar topic returns in later lessons through conversation, writing, and quiz tasks.",
        "Learners move from controlled patterns to freer communication at every level."
      ],
      "coverage": [
        "parts of speech",
        "sentence structure",
        "simple present, present continuous, simple past, past continuous, past perfect",
        "future forms with will and going to",
        "present perfect and present perfect continuous",
        "articles and quantifiers",
        "prepositions and direction language",
        "comparatives and superlatives",
        "modals for ability, permission, advice, obligation, certainty, speculation",
        "conditionals from basic to advanced",
        "active and passive voice",
        "direct and indirect speech",
        "relative clauses, noun clauses, gerunds, infinitives",
        "complex sentence connectors",
        "formal and professional English usage"
      ]
    },
    "vocabulary_system": {
      "target_exposures": 2000,
      "categories": [
        "Daily life",
        "Business",
        "Travel",
        "Emotions",
        "Work",
        "Social",
        "Health",
        "Technology",
        "Leadership",
        "Community"
      ],
      "approach": "Each lesson introduces 10 structured words or phrases, mixes them with review items, and ties them to one communicative task.",
      "revision_cycles": [
        "same lesson review",
        "next lesson retrieval",
        "end-of-chapter recap",
        "end-of-level spiral review",
        "30-day spaced recall"
      ],
      "spaced_repetition_days": [
        1,
        3,
        7,
        14,
        30
      ]
    },
    "speaking_system": {
      "daily_speaking_prompt_model": "Every lesson includes one focused speaking task, one role-play context, one confidence instruction, and one think-in-English drill.",
      "role_play_ladders": [
        "guided repetition",
        "supported role-play",
        "personalized response",
        "timed fluency response",
        "real-world simulation"
      ],
      "confidence_builders": [
        "chunk speaking instead of word-by-word translation",
        "content before perfection",
        "repeat with one improvement",
        "speak with pauses, not panic",
        "finish the thought before self-correcting"
      ]
    },
    "progression_system": {
      "unlock_logic": {
        "first_lesson_unlocked_by_default": true,
        "next_lesson_unlocks_after_completion": true,
        "next_chapter_unlocks_after_all_chapter_lessons_completed": true,
        "next_level_unlocks_after_previous_level_completed": true
      },
      "mastery_rules": [
        "Mark lesson complete after speaking task, writing task, and quiz are submitted.",
        "Recommend review when quiz score is below 70%.",
        "Promote to the next level after 80% lesson completion plus capstone completion."
      ]
    }
